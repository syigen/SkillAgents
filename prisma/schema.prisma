// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @db.Uuid
  templates          Template[]
  agentInvites       AgentInvite[]
  agents             Agent[]
  runs               Run[]
  skillClaims        AgentSkillClaim[]
  issuedCertificates Certificate[]
  settings           UserSettings?     @relation(fields: [userSettingsId], references: [id])
  userSettingsId     String?           @db.Uuid

  @@map("users")
}

model UserSettings {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  googleAiKeyEnc String?  @map("google_ai_key_enc")
  googleAiKeyIv  String?  @map("google_ai_key_iv")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  users          User[]

  @@map("user_settings")
}

model Template {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId String   @map("owner_user_id") @db.Uuid
  name        String
  description String?
  skills      Json     @default("[]")
  difficulty  String
  status      String   @default("draft")
  lastUpdated DateTime @default(now()) @updatedAt @map("last_updated") @db.Timestamptz()
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  owner        User                @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  criteria     TemplateCriterion[]
  agentInvites AgentInvite[]
  runs         Run[]

  @@index([ownerUserId])
  @@index([status])
  @@map("templates")
}

model TemplateCriterion {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId String   @map("template_id") @db.Uuid
  prompt     String
  expected   String
  minScore   Int      @map("min_score")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("template_criteria")
}

model AgentInvite {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId String    @map("owner_user_id") @db.Uuid
  templateId  String    @map("template_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash")
  status      String    @default("active")
  maxUses     Int?      @map("max_uses")
  uses        Int       @default(0)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  owner    User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  runs     Run[]

  @@index([ownerUserId])
  @@index([templateId])
  @@index([status])
  @@map("agent_invites")
}

model Agent {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId           String   @unique @map("agent_id")
  ownerUserId       String?  @map("owner_user_id") @db.Uuid
  clientRequestId   String   @map("client_request_id")
  name              String
  version           String   @default("1.0")
  fingerprint       String   @default("")
  fingerprintMethod String   @default("none") @map("fingerprint_method")
  toolAccess        Json     @default("[]") @map("tool_access")
  skillMdHash       String   @default("") @map("skill_md_hash")
  workspaceFiles    String?  @map("workspace_files")
  apiKeyHash        String   @map("api_key_hash")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  owner        User?             @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  runs         Run[]
  skillClaims  AgentSkillClaim[]
  certificates Certificate[]

  @@unique([ownerUserId, clientRequestId], map: "uq_agent_owner_clientreq")
  @@map("agents")
}

model Run {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId    String    @map("owner_user_id") @db.Uuid
  agentFkId      String    @map("agent_fk_id") @db.Uuid
  templateId     String    @map("template_id") @db.Uuid
  inviteId       String?   @map("invite_id") @db.Uuid
  status         String    @default("running")
  score          Int?
  evaluatedAt    DateTime? @map("evaluated_at") @db.Timestamptz()
  isLocked       Boolean   @default(false) @map("is_locked")
  questions      Json      @default("[]")
  questionSource String    @default("static") @map("question_source")
  templateName   String?   @map("template_name")
  timestamp      DateTime  @default(now()) @db.Timestamptz()

  owner    User         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  agent    Agent        @relation(fields: [agentFkId], references: [id], onDelete: Cascade)
  template Template     @relation(fields: [templateId], references: [id], onDelete: Restrict)
  invite   AgentInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  steps          RunStep[]
  questionScores RunQuestionScore[]
  skillClaims    AgentSkillClaim[]
  certificate    Certificate?
  evaluation     RunEvaluation?

  @@index([ownerUserId])
  @@index([agentFkId])
  @@index([templateId])
  @@map("runs")
}

model RunStep {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId         String   @map("run_id") @db.Uuid
  role          String
  content       String
  score         Int?
  isHumanGraded Boolean  @default(false) @map("is_human_graded")
  humanNote     String?  @map("human_note")
  timestamp     DateTime @default(now()) @db.Timestamptz()

  run            Run            @relation(fields: [runId], references: [id], onDelete: Cascade)
  gradingHistory RunStepGrade[]

  @@index([runId])
  @@map("run_steps")
}

model RunStepGrade {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stepId    String   @map("step_id") @db.Uuid
  score     Int
  reasoning String
  type      String
  isElected Boolean  @default(false) @map("is_elected")
  givenAt   DateTime @default(now()) @map("given_at") @db.Timestamptz()
  electedAt DateTime @default(now()) @map("elected_at") @db.Timestamptz()

  step RunStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([stepId])
  @@map("run_step_grades")
}

model RunEvaluation {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId          String   @unique @map("run_id") @db.Uuid
  overall        Int
  passThreshold  Int      @map("pass_threshold")
  skillThreshold Int      @map("skill_threshold")
  model          String?
  version        String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  run         Run                        @relation(fields: [runId], references: [id], onDelete: Cascade)
  skillScores RunEvaluationSkillScore[]
  perQuestion RunEvaluationPerQuestion[]

  @@index([runId])
  @@map("run_evaluations")
}

model RunEvaluationSkillScore {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  evaluationId String @map("evaluation_id") @db.Uuid
  skill        String
  score        Int

  evaluation RunEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, skill])
  @@index([evaluationId])
  @@map("run_evaluation_skill_scores")
}

model RunEvaluationPerQuestion {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  evaluationId  String  @map("evaluation_id") @db.Uuid
  questionIndex Int     @map("question_index")
  score         Int
  maxScore      Int     @map("max_score")
  feedback      String?

  evaluation  RunEvaluation                     @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  skillScores RunEvaluationQuestionSkillScore[]

  @@unique([evaluationId, questionIndex])
  @@index([evaluationId])
  @@map("run_evaluation_per_question")
}

model RunEvaluationQuestionSkillScore {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId String @map("question_id") @db.Uuid
  skill      String
  score      Int

  question RunEvaluationPerQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, skill])
  @@index([questionId])
  @@map("run_evaluation_question_skill_scores")
}

model RunQuestionScore {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId         String   @map("run_id") @db.Uuid
  questionIndex Int      @map("question_index")
  score         Int
  maxScore      Int      @map("max_score")
  perSkill      Json     @default("{}") @map("per_skill")
  feedback      String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, questionIndex])
  @@index([runId])
  @@map("run_question_scores")
}

model AgentSkillClaim {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentFkId        String   @map("agent_fk_id") @db.Uuid
  ownerUserId      String   @map("owner_user_id") @db.Uuid
  skillId          String   @map("skill_id")
  proficiencyClaim String   @default("verified") @map("proficiency_claim")
  runId            String   @map("run_id") @db.Uuid
  evidence         Json     @default("{}")
  status           String
  decidedBy        String   @default("ai") @map("decided_by")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  agent     Agent           @relation(fields: [agentFkId], references: [id], onDelete: Cascade)
  owner     User            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  run       Run             @relation(fields: [runId], references: [id], onDelete: Cascade)
  decisions ClaimDecision[]

  @@unique([agentFkId, ownerUserId, skillId])
  @@index([agentFkId])
  @@index([ownerUserId])
  @@index([status])
  @@map("agent_skill_claims")
}

model ClaimDecision {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  claimId    String   @map("claim_id") @db.Uuid
  source     String
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  reasoning  String?
  payload    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  claim AgentSkillClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_decisions")
}

model Certificate {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId        String   @unique @map("run_id") @db.Uuid
  agentFkId    String   @map("agent_fk_id") @db.Uuid
  agentName    String   @map("agent_name")
  templateName String?  @map("template_name")
  score        Int
  status       String   @default("active")
  issuedAt     DateTime @default(now()) @map("issued_at") @db.Timestamptz()
  issuedById   String?  @map("issued_by") @db.Uuid
  dataHash     String   @map("data_hash")
  snapshot     Json?

  run      Run   @relation(fields: [runId], references: [id], onDelete: Cascade)
  agent    Agent @relation(fields: [agentFkId], references: [id], onDelete: Cascade)
  issuedBy User? @relation(fields: [issuedById], references: [id], onDelete: SetNull)

  @@index([agentFkId])
  @@index([status])
  @@map("certificates")
}
